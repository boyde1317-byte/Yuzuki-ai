# ════════════════════════════════════════════════════════════════════════════
# YUZUKI AI — Environment Configuration
#
# VPS / Docker:    copy to .env, fill in values, run docker-compose up -d
# Pterodactyl:     set these as Egg Variables in the panel (no .env needed)
#
# IMPORTANT: Never commit .env to Git — it contains secrets!
# ════════════════════════════════════════════════════════════════════════════

# ── Bot Identity (REQUIRED) ──────────────────────────────────────────────────
# Phone number of the bot owner — digits only, country code included, no +
# This is used for pairing AND for owner-only command access control.
# Example: Ghana +233533416608 → 233533416608
OWNER_NUMBER=

BOT_NAME=Yuzuki AI
PREFIX=.
VERSION=2.0.0

# ── Behaviour ────────────────────────────────────────────────────────────────
AUTO_READ=false
AUTO_TYPING=false
AUTO_RECORDING=false
PUBLIC_MODE=true

# ── AI Provider ──────────────────────────────────────────────────────────────
# auto | groq | gemini | openrouter | pollinations
# "auto" picks the first provider with a configured key (chain below).
# If no keys are set, Pollinations.ai is used (free, no key required).
AI_PROVIDER=auto

# Custom fallback chain (comma-separated, overrides auto order):
# Example: AI_FALLBACK_CHAIN=groq,gemini,openrouter,pollinations
AI_FALLBACK_CHAIN=

# ── Groq (FREE tier — recommended) ───────────────────────────────────────────
# Get key: https://console.groq.com  (no credit card)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Google Gemini (FREE tier) ─────────────────────────────────────────────────
# Get key: https://aistudio.google.com  (no credit card)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# ── OpenRouter (FREE models available) ───────────────────────────────────────
# Get key: https://openrouter.ai  (free models end with :free)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ── Pollinations.ai (NO KEY — always available as fallback) ──────────────────
POLLINATIONS_MODEL=openai-large

# ── GitHub (src/commands/github.js) ──────────────────────────────────────────
# Personal Access Token — gives 5000 req/hr (vs 60/hr unauthenticated).
# Code search (.gh code) requires a PAT with repo or read:code scope.
# Create one: https://github.com/settings/tokens → Fine-grained or Classic
# Minimum scopes: public_repo (or repo for private), read:org
GITHUB_PERSONAL_ACCESS_TOKEN=

# ── Downloader (src/commands/downloader.js) ──────────────────────────────────
# Cobalt is a privacy-respecting open-source media downloader.
# Default: https://api.cobalt.tools (public instance — rate limited)
# Self-host: https://github.com/imputnet/cobalt (no limits)
COBALT_API_URL=

# ── Paths ────────────────────────────────────────────────────────────────────
# Docker/Pterodactyl: override with absolute paths inside the container.
# docker-compose.yml sets these to /data/* automatically.
SESSION_DIR=./session
DB_PATH=./database.sqlite
TEMP_DIR=./temp
LOGS_DIR=./logs

# ── Network ──────────────────────────────────────────────────────────────────
# Health endpoint: GET http://<host>:PORT/health
# Pterodactyl: set PORT to your egg's allocated port.
PORT=3000

# ── Reconnection ─────────────────────────────────────────────────────────────
# MAX_RECONNECT — max consecutive failures before exiting.
# Set to 0 for unlimited (recommended on Pterodactyl — let the panel restart).
# Set to 10–20 on VPS with PM2/systemd so the process manager gets a clean exit.
MAX_RECONNECT=0

# Base delay between reconnect attempts (ms). Actual delay uses exponential
# backoff with jitter: delay * 2^attempt + random(0..2000), capped at 60s.
RECONNECT_DELAY=3000

# DEBUG=true enables verbose Baileys protocol logs (very noisy — dev only)
DEBUG=false

# ── Lab flags ────────────────────────────────────────────────────────────────
# LAB_COMMERCE_MODE=true  unlocks owner-only commerce experiment commands:
#   .teststorefront  .testcollection  .testcatalog  .testproduct  .testcommerce
# These commands send raw proto payloads — NEVER enable in production.
# Only set this on a development / staging bot instance.
LAB_COMMERCE_MODE=false
# ── Menu offer overlay ────────────────────────────────────────────────────────
# MENU_OFFER_TEXT   — The offer/announcement body. The bot automatically
#                     prepends a time-aware greeting (Good morning! / afternoon!
#                     / evening!) so the text you set here is the static part.
#                     Leave empty to disable the offer card entirely.
# MENU_OFFER_URL    — URL the card links to when tapped (optional)
# MENU_OFFER_CODE   — Promo code displayed on the card e.g. YUZUKI30 (optional)
# MENU_OFFER_EXPIRY — Expiry as a Unix timestamp in SECONDS (NOT milliseconds).
#                     Example: 1785427200 = July 30 2026
#                     Get a timestamp: https://www.unixtimestamp.com
MENU_OFFER_URL=
MENU_OFFER_TEXT=📢 Yuzuki AI v2.1 — now with GPT-4o
MENU_OFFER_CODE=YUZUKI30
MENU_OFFER_EXPIRY=1785427200
